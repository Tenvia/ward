# Ward API
# Defaults shown here match the API unless a compose file overrides them.
# Full contract: docs/ENVIRONMENT.md

# Port the Ward API listens on.
PORT=4317

# Global mode: enforce blocks paused/constrained tenants; observe allows
# otherwise-valid traffic with x-ward-would-block + audit evidence.
WARD_MODE=enforce

# Deployment mode label shown per tenant: local | docker | kubernetes | hosted.
# This is a label only; it does not enable hosted/Kubernetes operation.
WARD_DEPLOYMENT_MODE=local

# Pressure detection window and threshold.
WARD_LOOP_WINDOW_MS=10000
WARD_LOOP_REQUEST_THRESHOLD=8

# Fixed fake per-request cost estimate (USD). Not a real cost model.
WARD_ESTIMATED_COST_PER_REQUEST=0.002

# Approval token TTL in milliseconds.
WARD_APPROVAL_TTL_MS=120000

# Proxy behavior when tenant policy lookup fails while the API is up:
# open allows the request with an x-ward-fail-open header and a
# proxy_fail_open audit event; closed blocks with 503. A successful
# policy read is ALWAYS enforced regardless of this setting.
WARD_PROXY_FAIL_MODE=open

# TEST-ONLY: force policy lookups to fail so fail modes can be exercised.
# Never enable outside local/test runs.
# WARD_TEST_FORCE_POLICY_ERROR=true

# Minimal shared-token control auth (prototype, not production RBAC).
# When required, mutating /ward/* endpoints need
# "Authorization: Bearer <WARD_CONTROL_TOKEN>". Reads stay open.
# Safe evaluator path: true + a long random token. Never expose Ward
# publicly with auth disabled; never reuse ward-demo-token beyond a demo.
WARD_REQUIRE_CONTROL_TOKEN=false
WARD_CONTROL_TOKEN=

# Control Room build-time settings. Avoid embedding real secrets in a
# built Control Room bundle; localStorage runtime token wins.
# VITE_WARD_API_URL=http://localhost:4317
# VITE_WARD_CONTROL_TOKEN=

# Storage backend: memory (default, lost on restart) | sqlite
# SQLite is prototype local persistence via Node's built-in node:sqlite
# (experimental in Node 22). It is not HA/shared/compliance storage.
WARD_STORAGE=memory
WARD_SQLITE_PATH=.ward/ward.db

# Docker runner (dev-only prototype). Disabled by default. Requires a
# local Docker daemon. Only allowlisted images run; no mounts, no
# privileged mode, hard timeout. Never expose on a shared/public host.
WARD_ENABLE_DOCKER_RUNNER=false
WARD_DOCKER_ALLOWED_IMAGES=ward-example-agent
WARD_DOCKER_RUN_TIMEOUT_MS=30000

# Pass-through upstream mode. Leave both unset to use the built-in mock
# upstream (no external LLM is called). Both must be set to enable
# non-streaming pass-through; real upstream SSE streaming is not claimed.
# WARD_UPSTREAM_OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...

# Compose / image pinning.
# WARD_IMAGE=ghcr.io/tenvia/ward-api:v0.1.0-rc4
# WARD_IMAGE_NAME=ghcr.io/tenvia/ward-api
# WARD_IMAGE_TAG=dev

# Packaging/internal overrides. Normal evaluators should not need these.
# WARD_OPENAPI_DIR=openapi
# WARD_UI_DIR=ui

# Tooling and smoke targets.
# WARD_API_URL=http://localhost:4317
# WARD_DEMO_URL=http://localhost:4401
# WARD_BENCH_REQUESTS=50

# Demo SaaS / example agent.
# WARD_PROXY_BASE_URL=http://localhost:4317
# WARD_BASE_URL=http://localhost:4317
# WARD_TENANT_ID=tenant_globex
# AGENT_STEPS=5
# AGENT_STEP_DELAY_MS=1000
